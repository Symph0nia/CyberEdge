    "GetScope",
    "StartAssessment",
    "GetTask",
    "WatchTask",
    "CancelTask",
    "SearchAssets",
    "SearchServices",
    "SearchCertificates",
    "SearchWebsites",
    "SearchFindings",
    "SearchObservations",
    "GetEvidence",
    "GetTaskReport",
    "SearchAudit"
  ]
}
